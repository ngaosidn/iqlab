{
    "java.configuration.updateBuildConfiguration": "automatic",
    "java.compile.nullAnalysis.mode": "automatic",
    "java.import.excludes": [
        "**/node_modules/**",
        "**/mobile/node_modules/**",
        "**/android/**/.settings/**",
        "**/android/**/bin/**",
        "**/android/**/.project",
        "**/expo-modules-autolinking/android/expo-gradle-plugin/**",
        "**/expo-modules-core/expo-module-gradle-plugin/**"
    ],
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/node_modules": true,
        "**/.settings": true,
        "**/.project": true,
        "**/bin": true
    },
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/*/**": true,
        "**/mobile/node_modules/**": true
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/bower_components": true,
        "**/*.code-search": true,
        "**/mobile/node_modules": true
    }
}